<h1>authors</h1>
<a href="/authors/form">add a new author</a>
<ul>
{{!-- using built-in helper for each --}}
 {{#each authors}}
   <li>
      <a href="/authors/form?id={{this.id}}">{{this.id}}: {{this.firstName}} {{this.lastName}}</a>
      <a href="/authors/edit?id={{@index}}">edit</a>
    </li>
 {{/each}}
</ul>