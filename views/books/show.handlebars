<h1>{{book.title}}</h1>

{{!-- the code below checks if we have an author set then loops over the authors and makes them into a comma separated list. {{#unless last}} makes sure we don't add a comma after the last author. --}}

{{#if authors}}
<p>written by {{#each authors}}{{this.firstName}} {{this.lastName}}{{#unless @last}}, {{/unless}}{{/each}}</p>
{{/if}}

<p>originally published in {{book.publicationYear}}</p>

{{#if genres}}
<p>genre: {{#each genres}}{{this.genreName}}{{#unless @last}}, {{/unless}}{{/each}}</p>
{{/if}}

{{#if currentUser}}
<div>
  <form action="/books_users/upsert" role="form" method="post">
    <input type="hidden" name="_csrf" value="{{_csrfToken}}">
    <input type="hidden" name="bookId" value="{{bookId}}">
    <input type="hidden" name="userId" value="{{currentUser.id}}">
    {{if bookUser}}
        <input type="hidden" name="id" value="{{bookUser.id}}">
    {{/if}}
    <label for="status">status</label>
    <select name="status" id="status">
      {{#unless (and bookUser bookUser.status)}}
        <option disabled value selected> select status </option>
      {{/unless}}
      {{#each statuses}}
        <option value="{{this}}" {{#if (and @root.bookUser (eq @root.bookUser.status this))}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
    <button type="submit">submit</button>
  </form>
</div>
{{/if}}

<div>
  <h2>comments</h2>
  <div>
    {{#if currentUser}}
      <form action="/comments/upsert" role="form" method="post">
        <input type="hidden" name="_csrf" value="{{_csrfToken}}">
        <input type="hidden" name="bookId" value="{{bookId}}">
        <input type="hidden" name="userId" value="{{currentUser.id}}">
        <div>
          <textarea rows="5" id="comment" name="comment">{{comment.comment}}</textarea>
        </div>
        <button type="submit" class="btn btn-primary">new comment</button>
      </form>
    {{/if}}
    {{#each comments}}
      <div>
        <p>
          {{this.comment}}<br>
          By {{this.userEmail}}
          {{#if (eq @root.currentUser.id this.userId) }}
          <br><a href="/comments/edit?id={{this.id}}">Edit</a>
          {{/if}}
      </div>
    {{/each}}
  </div>
</div>
